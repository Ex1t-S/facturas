{
  "name": "facturas",
  "version": "1.0.0",
  "description": "MVP para ordenar presupuestos, documentos, facturas y asistencia por WhatsApp para una pyme argentina.",
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "dev:backend": "tsx watch src/server.ts",
    "dev:frontend": "vite --config frontend/vite.config.ts --host 0.0.0.0",
    "start": "node dist/server.js",
    "prestart": "prisma generate",
    "build": "tsc -p tsconfig.json && tsx scripts/copyGeneratedClient.ts && vite build --config frontend/vite.config.ts",
    "build:backend": "tsc -p tsconfig.json",
    "build:frontend": "vite build --config frontend/vite.config.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "prisma:generate": "prisma generate",
    "prisma:generate:sqlite": "prisma generate --schema prisma/schema.sqlite.prisma",
    "prisma:generate:all": "npm run prisma:generate && npm run prisma:generate:sqlite",
    "prisma:migrate": "prisma migrate dev",
    "prisma:push": "prisma db push",
    "prisma:studio": "prisma studio",
    "seed": "tsx prisma/seed.ts",
    "analyze:historical": "tsx scripts/analyzeHistoricalDocuments.ts",
    "import:inventory-candidates": "tsx scripts/importInventoryCandidates.ts",
    "extract:billing-clients": "tsx scripts/extractBillingClients.ts",
    "catalog:refine": "tsx scripts/refineProductCatalog.ts",
    "db:migrate:sqlite-to-postgres": "tsx scripts/migrateSqliteToPostgres.ts",
    "restore:documents": "tsx scripts/restoreRenderDocuments.ts",
    "engineering:ingest": "tsx scripts/engineeringIngest.ts",
    "engineering:drawings": "tsx scripts/engineeringDrawingsIngest.ts",
    "engineering:doctor": "tsx scripts/engineeringDoctor.ts",
    "engineering:sources:sync": "tsx scripts/engineeringSourcesSync.ts",
    "engineering:sources:check": "tsx scripts/engineeringSourcesSync.ts",
    "engineering:sources:status": "tsx scripts/engineeringSourcesStatus.ts",
    "engineering:benchmarks:extract": "tsx scripts/engineeringBenchmarksExtract.ts",
    "engineering:catalog:import": "tsx scripts/engineeringCatalogImport.ts",
    "engineering:projects:suggest": "tsx scripts/engineeringProjectsSuggest.ts",
    "engineering:drawings:process": "tsx scripts/engineeringDrawingsProcess.ts",
    "engineering:golden:validate": "tsx scripts/engineeringGoldenValidate.ts",
    "test:whatsapp:e2e": "tsx scripts/whatsappControlledE2e.ts",
    "test:whatsapp:conversations": "tsx scripts/whatsappConversationSimulation.ts",
    "preview:fmh-layout": "tsx scripts/fmhLayoutPreview.ts",
    "engineering:review": "tsx scripts/engineeringReviewWizard.ts",
    "engineering:review:direct": "tsx scripts/engineeringReviewWizard.ts --direct",
    "engineering:finalization:status": "tsx scripts/engineeringFinalizationStatus.ts",
    "engineering:finalization:status:direct": "tsx scripts/engineeringFinalizationStatus.ts --direct --write-doc",
    "engineering:finalization:bootstrap": "tsx scripts/engineeringFinalizationBootstrap.ts",
    "copy:generated-client": "tsx scripts/copyGeneratedClient.ts",
    "render": ".\\tools\\render\\render.exe",
    "render:login": ".\\tools\\render\\render.exe login",
    "render:services": ".\\tools\\render\\render.exe services",
    "render:blueprint:validate": ".\\tools\\render\\render.exe blueprints validate render.yaml",
    "neon": "neonctl",
    "neon:auth": "neon auth",
    "neon:projects": "neon projects list"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@fastify/helmet": "^13.0.2",
    "@fastify/multipart": "^10.0.0",
    "@fastify/static": "^9.1.3",
    "@prisma/client": "^6.19.3",
    "@vitejs/plugin-react": "^6.0.2",
    "adm-zip": "^0.5.17",
    "bcryptjs": "^3.0.3",
    "docx": "^9.7.1",
    "dotenv": "^17.4.2",
    "fastify": "^5.8.5",
    "lucide-react": "^1.21.0",
    "mammoth": "^1.12.0",
    "nanoid": "^5.1.15",
    "pdf-parse": "^2.4.5",
    "pdfkit": "^0.19.1",
    "qrcode": "^1.5.4",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "sanitize-html": "^2.17.5",
    "vite": "^8.0.16",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.8",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^26.0.0",
    "@types/pdfkit": "^0.17.6",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/sanitize-html": "^2.16.1",
    "neonctl": "^2.27.0",
    "prisma": "^6.19.3",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}
