{
  "name": "facturas",
  "version": "1.0.0",
  "description": "MVP para ordenar presupuestos, documentos, facturas y asistencia por WhatsApp para una pyme argentina.",
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "dev:backend": "tsx watch src/server.ts",
    "dev:frontend": "vite --config frontend/vite.config.ts --host 0.0.0.0",
    "start": "node dist/server.js",
    "build": "tsc -p tsconfig.json && vite build --config frontend/vite.config.ts",
    "build:backend": "tsc -p tsconfig.json",
    "build:frontend": "vite build --config frontend/vite.config.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:studio": "prisma studio",
    "seed": "tsx prisma/seed.ts",
    "demo:documents": "tsx scripts/createDemoDocuments.ts",
    "analyze:historical": "tsx scripts/analyzeHistoricalDocuments.ts",
    "import:inventory-candidates": "tsx scripts/importInventoryCandidates.ts",
    "extract:billing-clients": "tsx scripts/extractBillingClients.ts",
    "catalog:refine": "tsx scripts/refineProductCatalog.ts",
    "demo:fmh-quote": "tsx scripts/createFmhDemoQuote.ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@fastify/helmet": "^13.0.2",
    "@fastify/multipart": "^10.0.0",
    "@fastify/static": "^9.1.3",
    "@prisma/client": "^6.19.3",
    "@vitejs/plugin-react": "^6.0.2",
    "adm-zip": "^0.5.17",
    "bcryptjs": "^3.0.3",
    "docx": "^9.7.1",
    "dotenv": "^17.4.2",
    "fastify": "^5.8.5",
    "lucide-react": "^1.21.0",
    "mammoth": "^1.12.0",
    "nanoid": "^5.1.15",
    "pdf-parse": "^2.4.5",
    "pdfkit": "^0.19.1",
    "qrcode": "^1.5.4",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "sanitize-html": "^2.17.5",
    "vite": "^8.0.16",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.8",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^26.0.0",
    "@types/pdfkit": "^0.17.6",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/sanitize-html": "^2.16.1",
    "prisma": "^6.19.3",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}
