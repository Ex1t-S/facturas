generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/sqlite-client"
}

datasource db {
  provider = "sqlite"
  url      = env("SQLITE_DATABASE_URL")
}

enum UserRole {
  ADMIN
  OPERATOR
  VIEWER
}

enum QuoteStatus {
  DRAFT
  SENT
  ACCEPTED
  REJECTED
  EXPIRED
  INVOICED
}

enum DocumentStatus {
  PENDING_REVIEW
  REVIEWED
  REJECTED
}

enum DocumentKind {
  QUOTE
  INVOICE
  PURCHASE_INVOICE
  DELIVERY_NOTE
  UNKNOWN
}

enum ExtractionStatus {
  UPLOADED
  TEXT_EXTRACTED
  STRUCTURED
  NEEDS_REVIEW
  APPROVED
  APPLIED
  FAILED
}

enum CatalogEntityType {
  CUSTOMER
  PRODUCT
  MATERIAL
  SERVICE
}

enum MatchDecision {
  PENDING
  ACCEPTED
  REJECTED
  CREATED
  MERGED
}

enum StockMovementSource {
  DOCUMENT_IMPORT
  QUOTE_RESERVED
  INVOICE_CONFIRMED
  MANUAL
}

enum InvoiceStatus {
  DRAFT
  PENDING_CONFIRMATION
  AUTHORIZED
  REJECTED
  CANCELLED
}

enum MessageDirection {
  INBOUND
  OUTBOUND
}

model User {
  id           String     @id @default(cuid())
  name         String
  email        String     @unique
  role         UserRole   @default(OPERATOR)
  passwordHash String
  active       Boolean    @default(true)
  createdAt    DateTime   @default(now())
  quotes       Quote[]
  auditLogs    AuditLog[]
}

model Company {
  id           String     @id @default(cuid())
  legalName    String
  tradeName    String?
  cuit         String     @unique
  taxCondition String
  address      String?
  phone        String?
  email        String?
  createdAt    DateTime   @default(now())
  customers    Customer[]
  deliveryNotes DeliveryNote[]
  products     Product[]
  suppliers    Supplier[]
  supplierPriceLists SupplierPriceList[]
  assistantChats AssistantChat[]
  engineeringKnowledgeDocuments EngineeringKnowledgeDocument[]
  engineeringProjects EngineeringProject[]
  engineeringCalculations EngineeringCalculation[]
  engineeringIngestionRuns EngineeringIngestionRun[]
  engineeringConversations EngineeringConversation[]
  engineeringCases EngineeringCase[]
  engineeringRegulations EngineeringRegulation[]
  engineeringDrawings EngineeringDrawingDocument[]
  engineeringDrawingTemplates EngineeringDrawingTemplate[]
}

model Supplier {
  id          String   @id @default(cuid())
  companyId   String
  name        String
  cuit        String?
  phone       String?
  email       String?
  website     String?
  notes       String?
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  company     Company  @relation(fields: [companyId], references: [id])
  priceLists  SupplierPriceList[]
  prices      SupplierProductPrice[]

  @@unique([companyId, name])
  @@index([companyId])
}

model SupplierPriceList {
  id          String   @id @default(cuid())
  companyId   String
  supplierId  String
  name        String
  sourceType  String   @default("manual")
  documentId  String?
  currency    String   @default("ARS")
  validFrom   DateTime @default(now())
  importedAt  DateTime @default(now())
  notes       String?
  company     Company  @relation(fields: [companyId], references: [id])
  supplier    Supplier @relation(fields: [supplierId], references: [id])
  prices      SupplierProductPrice[]

  @@index([companyId])
  @@index([supplierId])
}

model Customer {
  id           String            @id @default(cuid())
  companyId    String
  legalName    String
  tradeName    String?
  cuit         String?
  taxCondition String?
  address      String?
  contactName  String?
  phone        String?
  email        String?
  paymentTerms String?
  notes        String?
  createdAt    DateTime          @default(now())
  company      Company           @relation(fields: [companyId], references: [id])
  quotes       Quote[]
  invoices     Invoice[]
  deliveryNotes DeliveryNote[]
  whatsapp     WhatsAppMessage[]
  candidates   CustomerCandidate[]

  @@index([companyId])
}

model Product {
  id          String      @id @default(cuid())
  companyId   String
  sku         String?
  name        String
  type        String      @default("PRODUCT")
  normalizedName String?
  aliasesJson String?
  metadataJson String?
  description String?
  unit        String      @default("unidad")
  category    String?
  baseCost    Decimal     @default(0)
  lastCost    Decimal?
  price       Decimal
  taxRate     Decimal     @default(21)
  stockTracked Boolean    @default(false)
  active      Boolean     @default(true)
  createdAt   DateTime    @default(now())
  company     Company     @relation(fields: [companyId], references: [id])
  quoteItems  QuoteItem[]
  deliveryNoteItems DeliveryNoteItem[]
  invoiceItems InvoiceItem[]
  itemCandidates DocumentItemCandidate[]
  stocks      InventoryStock[]
  stockMovements StockMovement[]
  supplierPrices SupplierProductPrice[]

  @@index([companyId])
}

model SupplierProductPrice {
  id           String   @id @default(cuid())
  companyId    String
  supplierId   String
  priceListId  String?
  productId    String?
  supplierSku  String?
  rawName      String
  normalizedName String
  unit         String   @default("unidad")
  currency     String  @default("ARS")
  price        Decimal
  taxIncluded  Boolean @default(false)
  available    Boolean @default(true)
  observedAt   DateTime @default(now())
  notes        String?
  supplier     Supplier @relation(fields: [supplierId], references: [id])
  priceList    SupplierPriceList? @relation(fields: [priceListId], references: [id])
  product      Product? @relation(fields: [productId], references: [id])

  @@index([companyId])
  @@index([supplierId])
  @@index([productId])
  @@index([normalizedName])
}

model Quote {
  id          String      @id @default(cuid())
  companyId   String
  customerId  String
  number      Int
  version     Int         @default(1)
  status      QuoteStatus @default(DRAFT)
  issueDate   DateTime    @default(now())
  validUntil  DateTime?
  currency    String      @default("ARS")
  subtotal    Decimal     @default(0)
  taxTotal    Decimal     @default(0)
  total       Decimal     @default(0)
  notes       String?
  createdById String?
  customer    Customer    @relation(fields: [customerId], references: [id])
  createdBy   User?       @relation(fields: [createdById], references: [id])
  items       QuoteItem[]
  invoices    Invoice[]
  deliveryNoteLinks DeliveryNoteQuote[]

  @@unique([companyId, number, version])
  @@index([customerId])
}

model QuoteItem {
  id          String   @id @default(cuid())
  quoteId     String
  productId   String?
  description String
  quantity    Decimal
  unit        String   @default("unidad")
  unitPrice   Decimal
  discount    Decimal  @default(0)
  taxRate     Decimal  @default(21)
  total       Decimal
  quote       Quote    @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  product     Product? @relation(fields: [productId], references: [id])
}

model Document {
  id          String                @id @default(cuid())
  companyId   String?
  kind        DocumentKind          @default(UNKNOWN)
  sourceType  String
  fileName    String
  mimeType    String
  storagePath String
  sha256      String
  status      DocumentStatus        @default(PENDING_REVIEW)
  extractionStatus ExtractionStatus @default(UPLOADED)
  documentDate DateTime?
  issuerName  String?
  issuerCuit  String?
  externalNumber String?
  currency    String                @default("ARS")
  total       Decimal?
  uploadedBy  String?
  createdAt   DateTime              @default(now())
  extraction  DocumentExtraction?
  deliveryNote DeliveryNote?
  messages    WhatsAppMessage[]
  itemCandidates DocumentItemCandidate[]
  customerCandidates CustomerCandidate[]
  stockMovements StockMovement[]
}

model DocumentExtraction {
  id            String    @id @default(cuid())
  documentId    String    @unique
  engine        String?
  schemaVersion String    @default("v1")
  rawText       String?
  rawJson       String?
  normalizedJson String?
  extractedJson String?
  confidence    Decimal   @default(0)
  fieldConfidence String?
  errorMessage  String?
  reviewedBy    String?
  reviewedAt    DateTime?
  document      Document  @relation(fields: [documentId], references: [id], onDelete: Cascade)
}

model DocumentItemCandidate {
  id               String            @id @default(cuid())
  documentId       String
  lineNumber       Int
  rawDescription   String
  normalizedName   String?
  quantity         Decimal?
  unit             String?
  unitPrice        Decimal?
  total            Decimal?
  taxRate          Decimal?
  sku              String?
  category         String?
  entityType       CatalogEntityType @default(PRODUCT)
  matchedProductId String?
  confidence       Decimal           @default(0)
  decision         MatchDecision      @default(PENDING)
  reviewNotes      String?
  createdAt        DateTime          @default(now())
  document         Document          @relation(fields: [documentId], references: [id], onDelete: Cascade)
  matchedProduct   Product?          @relation(fields: [matchedProductId], references: [id])

  @@index([documentId])
  @@index([matchedProductId])
}

model CustomerCandidate {
  id                String        @id @default(cuid())
  documentId        String
  legalName         String?
  tradeName         String?
  cuit              String?
  taxCondition      String?
  address           String?
  matchedCustomerId String?
  confidence        Decimal       @default(0)
  decision          MatchDecision  @default(PENDING)
  document          Document      @relation(fields: [documentId], references: [id], onDelete: Cascade)
  matchedCustomer   Customer?     @relation(fields: [matchedCustomerId], references: [id])

  @@index([documentId])
  @@index([matchedCustomerId])
}

model InventoryStock {
  id          String   @id @default(cuid())
  companyId   String
  productId   String
  quantity    Decimal  @default(0)
  reserved    Decimal  @default(0)
  minQuantity Decimal?
  location    String   @default("principal")
  product     Product  @relation(fields: [productId], references: [id])

  @@unique([companyId, productId, location])
}

model StockMovement {
  id          String              @id @default(cuid())
  companyId   String
  productId   String
  documentId  String?
  quoteId     String?
  invoiceId   String?
  quantity    Decimal
  unitCost    Decimal?
  source      StockMovementSource
  reason      String
  createdAt   DateTime            @default(now())
  product     Product             @relation(fields: [productId], references: [id])
  document    Document?           @relation(fields: [documentId], references: [id])

  @@index([companyId])
  @@index([productId])
}

model Invoice {
  id               String        @id @default(cuid())
  companyId         String
  customerId        String
  quoteId           String?
  type              String
  pointOfSale       Int?
  number            Int?
  status            InvoiceStatus @default(DRAFT)
  issueDate         DateTime      @default(now())
  cae               String?
  caeDueDate        DateTime?
  currency          String        @default("ARS")
  subtotal          Decimal       @default(0)
  taxTotal          Decimal       @default(0)
  total             Decimal       @default(0)
  arcaResponseJson  String?
  customer          Customer      @relation(fields: [customerId], references: [id])
  quote             Quote?        @relation(fields: [quoteId], references: [id])
  items             InvoiceItem[]

  @@index([companyId, pointOfSale, type, number])
}

model InvoiceItem {
  id          String   @id @default(cuid())
  invoiceId   String
  productId   String?
  description String
  quantity    Decimal
  unitPrice   Decimal
  taxRate     Decimal
  total       Decimal
  invoice     Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  product     Product? @relation(fields: [productId], references: [id])
}

model WhatsAppMessage {
  id                String           @id @default(cuid())
  direction          MessageDirection
  fromNumber         String
  toNumber           String
  customerId         String?
  messageType        String
  body               String?
  mediaDocumentId    String?
  providerMessageId  String?          @unique
  status             String           @default("received")
  createdAt          DateTime         @default(now())
  customer           Customer?        @relation(fields: [customerId], references: [id])
  mediaDocument      Document?        @relation(fields: [mediaDocumentId], references: [id])
}

model AuditLog {
  id          String   @id @default(cuid())
  actorUserId String?
  entityType  String
  entityId    String
  action      String
  beforeJson  String?
  afterJson   String?
  createdAt   DateTime @default(now())
  actor       User?    @relation(fields: [actorUserId], references: [id])
}

model AssistantChat {
  id        String             @id @default(cuid())
  companyId String
  title     String             @default("Nuevo chat")
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt
  company   Company            @relation(fields: [companyId], references: [id], onDelete: Cascade)
  messages  AssistantMessage[]

  @@index([companyId, updatedAt])
}

model AssistantMessage {
  id         String        @id @default(cuid())
  chatId     String
  role       String
  content    String
  mode       String?
  sourcesJson String?
  actionType String?
  quoteId    String?
  documentId String?
  createdAt  DateTime      @default(now())
  chat       AssistantChat @relation(fields: [chatId], references: [id], onDelete: Cascade)

  @@index([chatId, createdAt])
  @@index([quoteId])
  @@index([documentId])
}

model DeliveryNote {
  id          String             @id @default(cuid())
  companyId   String
  customerId  String
  documentId  String?            @unique
  number      Int
  status      DeliveryNoteStatus @default(PENDING)
  issueDate   DateTime           @default(now())
  projectName String?
  currency    String             @default("ARS")
  total       Decimal?
  notes       String?
  company     Company            @relation(fields: [companyId], references: [id], onDelete: Cascade)
  customer    Customer           @relation(fields: [customerId], references: [id])
  document    Document?          @relation(fields: [documentId], references: [id])
  items       DeliveryNoteItem[]
  quoteLinks  DeliveryNoteQuote[]

  @@unique([companyId, number])
  @@index([companyId, customerId, status])
  @@index([companyId, issueDate])
}

model DeliveryNoteItem {
  id                String       @id @default(cuid())
  deliveryNoteId    String
  productId         String?
  description       String
  quantity          Decimal
  convertedQuantity  Decimal      @default(0)
  unit              String        @default("unidad")
  unitPrice         Decimal?
  priceOrigin       String?
  taxRate           Decimal       @default(21)
  deliveryNote      DeliveryNote  @relation(fields: [deliveryNoteId], references: [id], onDelete: Cascade)
  product           Product?      @relation(fields: [productId], references: [id])

  @@index([deliveryNoteId])
}

model DeliveryNoteQuote {
  id              String       @id @default(cuid())
  deliveryNoteId  String
  quoteId         String
  createdAt       DateTime     @default(now())
  deliveryNote    DeliveryNote @relation(fields: [deliveryNoteId], references: [id], onDelete: Cascade)
  quote           Quote        @relation(fields: [quoteId], references: [id], onDelete: Cascade)

  @@unique([deliveryNoteId, quoteId])
  @@index([quoteId])
}

enum DeliveryNoteStatus {
  DRAFT
  PENDING
  QUOTED
  INVOICED
  CANCELLED
}

model EngineeringKnowledgeDocument {
  id String @id @default(cuid())
  companyId String?
  sourceDocumentId String?
  fileName String
  relativePath String?
  extension String
  mimeType String
  sha256 String
  sizeBytes Int
  status String @default("DISCOVERED")
  documentType String @default("OTHER")
  projectType String @default("OTHER")
  projectName String?
  customerName String?
  documentDate DateTime?
  rawText String?
  structuredJson String?
  metadataJson String?
  extractorVersion String @default("engineering-extractor-v1")
  promptVersion String?
  model String?
  confidence Float @default(0)
  errorMessage String?
  verified Boolean @default(false)
  reviewNotes String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  company Company? @relation(fields: [companyId], references: [id], onDelete: Cascade)
  projects EngineeringProjectDocument[]
  reviews EngineeringReview[]
  vectorIndexes EngineeringVectorIndex[]
  @@unique([companyId, sha256])
  @@index([companyId, status])
  @@index([companyId, projectType])
  @@index([companyId, documentType])
}

model EngineeringProject {
  id String @id @default(cuid())
  companyId String
  name String
  projectType String @default("OTHER")
  customerName String?
  projectDate DateTime?
  status String @default("SUGGESTED")
  description String?
  technicalJson String?
  notes String?
  verified Boolean @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  documents EngineeringProjectDocument[]
  reviews EngineeringReview[]
  conversations EngineeringConversation[]
  @@index([companyId, projectType])
  @@index([companyId, status])
}

model EngineeringProjectDocument {
  id String @id @default(cuid())
  projectId String
  knowledgeId String
  project EngineeringProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  knowledge EngineeringKnowledgeDocument @relation(fields: [knowledgeId], references: [id], onDelete: Cascade)
  @@unique([projectId, knowledgeId])
  @@index([knowledgeId])
}

model EngineeringCalculation {
  id String @id @default(cuid())
  companyId String
  title String
  formula String?
  inputsJson String
  resultJson String
  source String @default("CALCULATED")
  createdAt DateTime @default(now())
  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  @@index([companyId, createdAt])
}

model EngineeringReview {
  id String @id @default(cuid())
  companyId String?
  knowledgeId String?
  projectId String?
  originalJson String?
  correctedJson String?
  status String @default("VERIFIED")
  note String?
  reviewerName String?
  createdAt DateTime @default(now())
  knowledge EngineeringKnowledgeDocument? @relation(fields: [knowledgeId], references: [id], onDelete: Cascade)
  project EngineeringProject? @relation(fields: [projectId], references: [id], onDelete: Cascade)
  @@index([companyId, status])
  @@index([knowledgeId])
  @@index([projectId])
}

model EngineeringIngestionRun {
  id String @id @default(cuid())
  companyId String?
  rootPath String
  status String @default("RUNNING")
  foundCount Int @default(0)
  newCount Int @default(0)
  unchangedCount Int @default(0)
  modifiedCount Int @default(0)
  processedCount Int @default(0)
  pendingCount Int @default(0)
  failedCount Int @default(0)
  lastError String?
  startedAt DateTime @default(now())
  finishedAt DateTime?
  company Company? @relation(fields: [companyId], references: [id], onDelete: Cascade)
  @@index([companyId, startedAt])
}

model EngineeringVectorIndex {
  id String @id @default(cuid())
  knowledgeId String
  vectorStoreId String
  openaiFileId String?
  localHash String
  status String @default("PENDING")
  indexedAt DateTime?
  errorMessage String?
  knowledge EngineeringKnowledgeDocument @relation(fields: [knowledgeId], references: [id], onDelete: Cascade)
  @@unique([knowledgeId, vectorStoreId])
  @@index([vectorStoreId, status])
}

model EngineeringConversation {
  id String @id @default(cuid())
  companyId String
  userId String?
  title String @default("Nuevo caso de Ingeniería")
  status String @default("OPEN")
  projectId String?
  stateJson String @default("{}")
  summaryJson String @default("{}")
  previousResponseId String?
  model String?
  currentIntent String?
  intentConfidence Float?
  lastProvider String?
  lastRequestedModel String?
  lastActualModel String?
  lastLatencyMs Int?
  lastErrorJson String?
  lastFallbackUsed Boolean @default(false)
  promptVersion String?
  archivedAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  project EngineeringProject? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  messages EngineeringMessage[]
  engineeringCase EngineeringCase?
  toolCalls EngineeringToolCall[]
  @@index([companyId, updatedAt])
  @@index([companyId, status])
}

model EngineeringMessage {
  id String @id @default(cuid())
  conversationId String
  role String
  content String
  model String?
  responseId String?
  provider String?
  requestedModel String?
  actualModel String?
  fallbackUsed Boolean @default(false)
  latencyMs Int?
  errorJson String?
  intent String?
  intentConfidence Float?
  tokenUsageJson String?
  estimatedCost Float?
  structuredResultJson String?
  createdAt DateTime @default(now())
  conversation EngineeringConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  @@index([conversationId, createdAt])
}

model EngineeringToolCall {
  id String @id @default(cuid())
  conversationId String
  messageId String?
  name String
  argumentsJson String
  resultJson String?
  status String @default("COMPLETED")
  durationMs Int?
  createdAt DateTime @default(now())
  conversation EngineeringConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  @@index([conversationId, createdAt])
}

model EngineeringCase {
  id String @id @default(cuid())
  companyId String
  conversationId String @unique
  name String
  projectType String @default("OTHER")
  customerName String?
  location String?
  status String @default("DRAFT")
  dataJson String @default("{}")
  assumptionsJson String @default("[]")
  calculationsJson String @default("[]")
  sourcesJson String @default("[]")
  regulationsJson String @default("[]")
  bomJson String @default("[]")
  costsJson String @default("{}")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  conversation EngineeringConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  @@index([companyId, status])
  @@index([companyId, projectType])
}

model EngineeringRegulation {
  id String @id @default(cuid())
  companyId String?
  code String
  title String
  jurisdiction String @default("AR")
  revision String?
  publicationDate DateTime?
  effectiveDate DateTime?
  status String @default("UNKNOWN")
  sourceUrl String?
  sourceDomain String?
  localDocumentId String?
  contentHash String?
  retrievedAt DateTime?
  verifiedAt DateTime?
  verifiedBy String?
  notes String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  company Company? @relation(fields: [companyId], references: [id], onDelete: Cascade)
  @@unique([companyId, code, revision])
  @@index([companyId, status])
}

model EngineeringDrawingTemplate {
  id String @id @default(cuid())
  companyId String?
  code String
  name String
  version String?
  sheetSize String?
  titleBlockPosition String?
  layoutJson String @default("{}")
  sampleCount Int @default(0)
  confidence Float @default(0)
  isDefault Boolean @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  company Company? @relation(fields: [companyId], references: [id], onDelete: Cascade)
  drawings EngineeringDrawingDocument[]
  @@unique([companyId, code])
  @@index([companyId, isDefault])
}

model EngineeringDrawingDocument {
  id String @id @default(cuid())
  companyId String
  templateId String?
  fileName String
  relativePath String
  sourcePath String
  sha256 String
  mimeType String @default("application/pdf")
  byteSize Int
  pageCount Int @default(0)
  status String @default("DISCOVERED")
  extractedText String?
  extractionJson String @default("{}")
  thumbnailPath String?
  drawingNumber String?
  projectName String?
  customerName String?
  projectType String?
  drawingTitle String?
  revision String?
  drawingDate DateTime?
  sheetSize String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  template EngineeringDrawingTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)
  @@unique([companyId, sha256])
  @@index([companyId, status])
  @@index([companyId, projectType])
  @@index([companyId, customerName])
}
